        <mxCell id="p_note" value="Recommended keying\nUse orderId/paymentId as Kafka partition key to preserve per-aggregate ordering instead of global locking." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
