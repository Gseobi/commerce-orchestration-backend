        </mxCell>
        <mxCell id="p_note2" value="Recommended persistence\nKeep PostgreSQL as source of truth and use Kafka for event propagation / replay / materialized history, not as the only business-state store." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
